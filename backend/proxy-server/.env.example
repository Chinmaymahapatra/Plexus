# ─────────────────────────────────────────────────────────────────────────────
# PLEXUS PROXY SERVER — ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your values in .env
#   3. NEVER commit .env to Git — it's in .gitignore
#   4. Share actual values with teammates via your private team Notion/doc
# ─────────────────────────────────────────────────────────────────────────────


# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Local dev: matches exactly what's in docker-compose.yml
# Don't change this unless you changed docker-compose too
DATABASE_URL=


# ─── REDIS ────────────────────────────────────────────────────────────────────
# Local dev: matches docker-compose.yml
REDIS_URL=


# ─── AUTH / JWT ───────────────────────────────────────────────────────────────
# Secret key used to sign developer JWT tokens (dashboard login)
# For local dev: any long random string works
# For production: generate with → python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-string-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=10080


# ─── STRIPE ───────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/test/apikeys
# Use TEST mode keys (sk_test_...) for development — never live keys locally
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_TEST_KEY
# Get this after running: stripe listen --forward-to localhost:8000/v1/webhooks/stripe
# Leave blank until you set up the Stripe CLI in Step 6 of setup guide
STRIPE_WEBHOOK_SECRET=


# ─── AWS ──────────────────────────────────────────────────────────────────────
# Needed for AWS Secrets Manager (where provider API keys are stored in prod)
# For local dev: leave blank — code falls back to DEV_*_KEY vars below
# For production: create an IAM user with SecretsManager read-only access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1


# ─── OPENAI (for semantic registry search) ────────────────────────────────────
# Used only to generate vector embeddings for API registry search
# NOT used for any AI inference — just embeddings
# Get from: https://platform.openai.com/api-keys
# Leave blank for MVP — semantic search is Phase 2
OPENAI_API_KEY=


# ─── APP CONFIG ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Credits granted to every new developer on signup (10000 = ~$10)
FREE_CREDITS_ON_SIGNUP=10000
# Percentage Plexus keeps on every API call (30 = 30%)
PLEXUS_MARGIN_PERCENT=30


# ─── LOCAL DEV API KEYS ───────────────────────────────────────────────────────
# In development, provider keys live here instead of AWS Secrets Manager
# These are YOUR personal test keys for local development only
# Get free keys from each provider's website
#
# OpenWeatherMap — free tier, 1000 calls/day
# Sign up at: https://openweathermap.org/api
DEV_OPENWEATHER_KEY=
#
# NewsAPI — free tier, 100 calls/day
# Sign up at: https://newsapi.org/register
DEV_NEWSAPI_KEY=
#
# CoinGecko — free tier, no signup needed for basic
# Sign up at: https://www.coingecko.com/en/api
DEV_COINGECKO_KEY=
#
# SerpAPI — paid, 100 free searches on signup
# Sign up at: https://serpapi.com/users/sign_up
DEV_SERPAPI_KEY=
#
# Apify — paid, $5 free credit on signup
# Sign up at: https://console.apify.com/sign-up
DEV_APIFY_KEY=
